{
  "name": "cook-cli",
  "version": "0.1.0",
  "description": "CLI-first scaffolding utility for .rcp recipes",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "bin": {
    "cook": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "commitlint": "commitlint --config commitlint.config.cjs",
    "lint": "eslint .",
    "release": "semantic-release",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "scaffold",
    "templates",
    "recipes"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/avanavana/cook-cli.git"
  },
  "homepage": "https://github.com/avanavana/cook-cli",
  "bugs": {
    "url": "https://github.com/avanavana/cook-cli/issues"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "ink": "^6.3.1",
    "react": "^19.2.0",
    "smol-toml": "^1.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
